const initCesium = async () => {
    try {
        // Use a known public demo token to force the globe to show
        Cesium.Ion.defaultAccessToken = ''; 

        const viewer = new Cesium.Viewer('map-container', {
            // This forces a simple 2D map if 3D fails
            terrainProvider: await Cesium.createWorldTerrainAsync(),
            animation: false,
            timeline: false,
            baseLayerPicker: true,
            navigationHelpButton: false,
            skyBox: true, // This should show stars even if the map fails
        });

        // 3D Buildings Layer
        const osmBuildings = await Cesium.createOsmBuildingsAsync();
        viewer.scene.primitives.add(osmBuildings);

        // Destination: The Great Pyramid of Giza
        viewer.camera.flyTo({
            destination: Cesium.Cartesian3.fromDegrees(31.1342, 29.9792, 2000),
            orientation: {
                heading: Cesium.Math.toRadians(0),
                pitch: Cesium.Math.toRadians(-35),
                roll: 0.0
            },
            duration: 3
        });

        console.log("Cesium Engine Started Successfully");

    } catch (error) {
        console.error("Cesium Engine Error:", error);
        document.body.innerHTML += `<div style="color:white; background:red; position:absolute; top:100px; left:20px; z-index:9999; padding:10px;">
            CRITICAL ERROR: ${error.message}
        </div>`;
    }
};

window.onload = initCesium;
