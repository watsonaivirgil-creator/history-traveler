   CHRONO-OS: app.js v2.5.1
   Logic: High-Fidelity Branching Data for Colosseum & Giza
*/

let viewer;
let currentSiteKey = "";

const historyData = {
    "Giza": { 
        name: "Pyramid of Giza", lat: 31.1342, lon: 29.9792, 
        baseFact: "The Great Pyramid is the last surviving ancient wonder, built around 2560 BC.", 
        img: "https://wikimedia.org",
        branches: [
            { label: "Engineering", text: "The pyramid was aligned to true north with an accuracy of within 3/60th of a degree." },
            { label: "The Worker Village", text: "Contrary to myth, the pyramids were built by paid laborers, not slaves, who lived in a nearby complex." },
            { label: "Stellar Alignment", text: "The shafts inside the pyramid point toward Orion’s Belt and the North Star." }
        ]
    },
    "Rome": { 
        name: "The Colosseum", lat: 12.49223, lon: 41.89021, 
        baseFact: "An iconic symbol of Imperial Rome, the Colosseum could host 80,000 spectators.", 
        img: "https://wikimedia.org",
        branches: [
            { label: "The Hypogeum", text: "The underground network featured 32 animal pens and manual elevators to hoist beasts into the arena." },
            { label: "Gladiator Classes", text: "Not all fighters were equal; the Murmillo carried heavy shields, while the Retiarius fought with a net and trident." },
            { label: "The Velarium", text: "A massive retractable awning managed by Roman sailors to shade spectators from the sun." },
            { label: "Public Executions", text: "Mid-day 'entertainment' often involved 'damnatio ad bestias'—execution by wild animals." }
        ]
    }
};

function init() {
    const status = document.getElementById('status-text');
    try {
        viewer = new Cesium.Viewer('map-container', {
            imageryProvider: new Cesium.UrlTemplateImageryProvider({
                url: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
                subdomains: ['a', 'b', 'c']
            }),
            baseLayerPicker: false, geocoder: false, timeline: false, animation: false,
            requestRenderMode: true
        });

        viewer.scene.primitives.add(Cesium.createOsmBuildings());

        Object.keys(historyData).forEach(key => {
            const site = historyData[key];
            viewer.entities.add({
                id: key,
                position: Cesium.Cartesian3.fromDegrees(site.lat, site.lon, 0),
                billboard: { 
                    image: 'https://wikimedia.org', 
                    width: 32, height: 32, verticalOrigin: Cesium.VerticalOrigin.BOTTOM
                },
                label: { 
                    text: site.name, font: '10pt serif', fillColor: Cesium.Color.GOLD, 
                    outlineColor: Cesium.Color.BLACK, outlineWidth: 2,
                    style: Cesium.LabelStyle.FILL_AND_OUTLINE, pixelOffset: new Cesium.Cartesian2(0, -45) 
                }
            });
        });

        viewer.screenSpaceEventHandler.setInputAction((movement) => {
            const picked = viewer.scene.pick(movement.position);
            if (picked && picked.id && historyData[picked.id.id]) {
                currentSiteKey = picked.id.id;
                openSidebar(historyData[currentSiteKey]);
                viewer.camera.flyTo({
                    destination: Cesium.Cartesian3.fromDegrees(historyData[currentSiteKey].lat, historyData[currentSiteKey].lon, 1000),
                    orientation: { pitch: Cesium.Math.toRadians(-35.0) }
                });
            }
        }, Cesium.ScreenSpaceEventType.LEFT_CLICK);

        status.innerText = "CHRONO-OS v2.5.1 ACTIVE";
    } catch (e) { status.innerText = "GPU ERROR"; }
}

function openSidebar(site) {
    const sidebar = document.getElementById('chat-sidebar');
    const messages = document.getElementById('chat-messages');
    document.getElementById('location-name').innerText = site.name;

    messages.innerHTML = `
        <img src="${site.img}" class="site-image">
        <p class="guide-text"><strong>Guide:</strong> ${site.baseFact}</p>
        <div id="branch-container"></div>
    `;
    
    const branchContainer = document.getElementById('branch-container');
    site.branches.forEach(branch => {
        const btn = document.createElement('button');
        btn.className = 'branch-btn';
        btn.innerText = branch.label;
        btn.onclick = () => {
            messages.innerHTML += `<p style="color:white; margin-top:15px; border-top: 1px solid #222; padding-top: 10px;"><strong>Query:</strong> ${branch.label}</p>`;
            messages.innerHTML += `<p class="guide-text"><strong>Guide:</strong> ${branch.text}</p>`;
            messages.scrollTop = messages.scrollHeight;
        };
        branchContainer.appendChild(btn);
    });

    sidebar.style.right = "0px";
}

function closeSidebar() { document.getElementById('chat-sidebar').style.right = "-400px"; }

window.sendMessage = function() {
    const input = document.getElementById('user-input');
    const messages = document.getElementById('chat-messages');
    if (input.value.trim() !== "") {
        const userQuery = input.value;
        messages.innerHTML += `<p style="color:white; margin-top:15px; border-top: 1px solid #222; padding-top: 10px;"><strong>Explorer:</strong> ${userQuery}</p>`;
        input.value = "";
        
        setTimeout(() => {
            messages.innerHTML += `<p class="guide-text"><strong>Guide:</strong> Searching archive for "${userQuery}"... The Chrono-Link is limited to localized data. Please utilize the branch chips for high-fidelity records.</p>`;
            messages.scrollTop = messages.scrollHeight;
        }, 800);
    }
};

window.onload = init;
