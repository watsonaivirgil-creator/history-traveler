// History Traveler: Cesium Engine (Open Source)
// No Google Billing Required

const initCesium = async () => {
    try {
        // 1. Initialize the viewer with a simple OpenStreetMap fallback
        const viewer = new Cesium.Viewer('map-container', {
            imageryProvider: new Cesium.OpenStreetMapImageryProvider({
                url : 'https://a.tile.openstreetmap.org/'
            }),
            terrainProvider: await Cesium.createWorldTerrainAsync(),
            baseLayerPicker: false,
            geocoder: false,
            homeButton: false,
            infoBox: false,
            selectionIndicator: false,
            timeline: false,
            animation: false
        });

        // 2. Add 3D Buildings
        try {
            const osmBuildings = await Cesium.createOsmBuildingsAsync();
            viewer.scene.primitives.add(osmBuildings);
        } catch (e) {
            console.log("3D Buildings failed, staying in 2D/Terrain mode.");
        }

        // 3. Jump to the Pyramids of Giza
        viewer.camera.setView({
            destination: Cesium.Cartesian3.fromDegrees(31.1342, 29.9792, 1500),
            orientation: {
                heading: Cesium.Math.toRadians(0),
                pitch: Cesium.Math.toRadians(-35)
            }
        });

    } catch (error) {
        console.error("Cesium startup error:", error);
        // Display the error directly on the screen so we can see it on the Chromebook
        document.body.innerHTML += `<div style="color:white; position:absolute; top:80px; left:20px; background:rgba(255,0,0,0.5); padding:10px;">
            MAP ENGINE ERROR: ${error.message}<br>
            Please check if WebGL is enabled in your browser settings.
        </div>`;
    }
};

window.onload = initCesium;
