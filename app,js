// History Traveler: Cesium Engine (Open Source)
// No Google Billing Required

const initCesium = async () => {
    // We use the default Ion token for basic 3D buildings/terrain
    // For production, you can get a free token at cesium.com/ion
    Cesium.Ion.defaultAccessToken = ''; 

    const viewer = new Cesium.Viewer('map-container', {
        terrainProvider: Cesium.createWorldTerrain(),
        animation: false,
        timeline: false,
        baseLayerPicker: false,
        navigationHelpButton: false,
        infoBox: true
    });

    // Add 3D Buildings (The 'History' Layer)
    const osmBuildings = await Cesium.createOsmBuildingsAsync();
    viewer.scene.primitives.add(osmBuildings);

    // Initial Destination: The Colosseum, Rome
    const destination = Cesium.Cartesian3.fromDegrees(12.4922, 41.8902, 1000);

    viewer.camera.flyTo({
        destination: destination,
        orientation: {
            heading: Cesium.Math.toRadians(0),
            pitch: Cesium.Math.toRadians(-35),
            roll: 0.0
        },
        duration: 5 // 5 second smooth intro flight
    });
};

window.onload = initCesium;
